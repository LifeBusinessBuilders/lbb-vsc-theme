{
  "name": "LBB Builder Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1E1E2B",
    "editor.foreground": "#E1E2EE",
    "editorLineNumber.foreground": "#616173",
    "editorLineNumber.activeForeground": "#E1E2EE",
    "editorGutter.background": "#151421",
    "editorCursor.foreground": "#83BDFF",
    "editorIndentGuide.background1": "#2C2C3C",
    "editorIndentGuide.activeBackground1": "#4B4B5D",
    "editorWhitespace.foreground": "#39384A",
    "editorRuler.foreground": "#2C2C3C",
    "sideBar.background": "#151421",
    "sideBar.foreground": "#C9C9D7",
    "sideBar.border": "#0C0C18",
    "sideBarSectionHeader.background": "#1E1E2B",
    "sideBarSectionHeader.foreground": "#E1E2EE",
    "sideBarTitle.foreground": "#E1E2EE",
    "activityBar.background": "#151421",
    "activityBar.foreground": "#E1E2EE",
    "activityBar.inactiveForeground": "#616173",
    "activityBarBadge.background": "#83BDFF",
    "activityBarBadge.foreground": "#0C0C18",
    "activityBar.activeBorder": "#83BDFF",
    "titleBar.activeBackground": "#151421",
    "titleBar.activeForeground": "#E1E2EE",
    "titleBar.inactiveBackground": "#151421",
    "titleBar.inactiveForeground": "#7A7A8C",
    "statusBar.background": "#151421",
    "statusBar.foreground": "#C9C9D7",
    "statusBar.noFolderBackground": "#151421",
    "statusBar.debuggingBackground": "#EC9DA3",
    "statusBar.debuggingForeground": "#0C0C18",
    "panel.background": "#151421",
    "panel.border": "#0C0C18",
    "panelTitle.activeForeground": "#E1E2EE",
    "panelTitle.inactiveForeground": "#616173",
    "list.hoverBackground": "#2C2C3C",
    "list.activeSelectionBackground": "#39384A",
    "list.activeSelectionForeground": "#E1E2EE",
    "list.inactiveSelectionBackground": "#2C2C3C",
    "list.inactiveSelectionForeground": "#E1E2EE",
    "list.highlightForeground": "#83BDFF",
    "editorGroup.border": "#0C0C18",
    "editorGroupHeader.tabsBackground": "#151421",
    "tab.activeBackground": "#1E1E2B",
    "tab.activeForeground": "#E1E2EE",
    "tab.inactiveBackground": "#151421",
    "tab.inactiveForeground": "#616173",
    "tab.border": "#151421",
    "tab.activeBorderTop": "#83BDFF",
    "tab.hoverBackground": "#2C2C3C",
    "focusBorder": "#83BDFF",
    "foreground": "#C9C9D7",
    "selection.background": "#83BDFF40",
    "editor.selectionBackground": "#4B4B5D80",
    "editor.inactiveSelectionBackground": "#39384A55",
    "editor.selectionHighlightBackground": "#39384A55",
    "editor.lineHighlightBackground": "#E1E2EE12",
    "editor.findMatchBackground": "#EED88666",
    "editor.findMatchHighlightBackground": "#EED88633",
    "editor.wordHighlightBackground": "#83BDFF26",
    "editor.wordHighlightStrongBackground": "#C3A2FC26",
    "editorBracketMatch.background": "#83BDFF26",
    "editorBracketMatch.border": "#83BDFF00",
    "editorError.foreground": "#F27972",
    "editorWarning.foreground": "#EED886",
    "editorInfo.foreground": "#84DBF2",
    "editorGutter.addedBackground": "#86DC90",
    "editorGutter.modifiedBackground": "#83BDFF",
    "editorGutter.deletedBackground": "#F27972",
    "gitDecoration.addedResourceForeground": "#86DC90",
    "gitDecoration.modifiedResourceForeground": "#EED886",
    "gitDecoration.deletedResourceForeground": "#F27972",
    "gitDecoration.untrackedResourceForeground": "#7FDCD4",
    "terminal.background": "#1E1E2B",
    "terminal.foreground": "#C9C9D7",
    "terminalCursor.foreground": "#83BDFF",
    "terminal.selectionBackground": "#4B4B5D80",
    "terminal.ansiBlack": "#39384A",
    "terminal.ansiRed": "#F27972",
    "terminal.ansiGreen": "#86DC90",
    "terminal.ansiYellow": "#EED886",
    "terminal.ansiBlue": "#83BDFF",
    "terminal.ansiMagenta": "#C3A2FC",
    "terminal.ansiCyan": "#7FDCD4",
    "terminal.ansiWhite": "#C9C9D7",
    "terminal.ansiBrightBlack": "#616173",
    "terminal.ansiBrightRed": "#EC9DA3",
    "terminal.ansiBrightGreen": "#86DC90",
    "terminal.ansiBrightYellow": "#F4AC6F",
    "terminal.ansiBrightBlue": "#84DBF2",
    "terminal.ansiBrightMagenta": "#F4ABCD",
    "terminal.ansiBrightCyan": "#84DBF2",
    "terminal.ansiBrightWhite": "#E1E2EE"
  },
  "semanticTokenColors": {
    "parameter": "#EC9DA3",
    "property": "#7FDCD4",
    "variable.readonly": "#EED886",
    "function": "#83BDFF",
    "method": "#83BDFF",
    "class": "#EED886",
    "interface": "#EED886",
    "enum": "#EED886",
    "type": "#EED886",
    "namespace": "#EED886",
    "enumMember": "#EED886",
    "typeParameter": "#F4AC6F",
    "decorator": "#F4AC6F"
  },
  "tokenColors": [
    {
      "settings": {
        "foreground": "#E1E2EE",
        "background": "#1E1E2B"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9FA0B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#86DC90"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#F4ABCD"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#83BDFF"
      }
    },
    {
      "name": "Keywords & Storage",
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#C3A2FC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "foreground": "#C3A2FC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#F4AC6F"
      }
    },
    {
      "name": "Boolean & Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#F4AC6F"
      }
    },
    {
      "name": "Variables & Identifiers",
      "scope": [
        "variable",
        "identifier",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#E1E2EE"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#EC9DA3"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#EED886"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#83BDFF"
      }
    },
    {
      "name": "Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#EED886"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#84DBF2"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#88899B"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#F4AC6F"
      }
    },
    {
      "name": "Constants & Enums",
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#EED886"
      }
    },
    {
      "name": "Object Keys",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7FDCD4"
      }
    },
    {
      "name": "Invalid & Deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#F27972"
      }
    },
    {
      "name": "Embedded Source",
      "scope": [
        "source.css.embedded",
        "source.js.embedded"
      ],
      "settings": {
        "foreground": "#84DBF2"
      }
    },
    {
      "name": "Inherited Class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown H1",
      "scope": [
        "markup.heading.1",
        "heading.1.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#C3A2FC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H2",
      "scope": [
        "markup.heading.2",
        "heading.2.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#83BDFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H3",
      "scope": [
        "markup.heading.3",
        "heading.3.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#84DBF2",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H4",
      "scope": [
        "markup.heading.4",
        "heading.4.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#7FDCD4",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H5",
      "scope": [
        "markup.heading.5",
        "heading.5.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#86DC90",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H6",
      "scope": [
        "markup.heading.6",
        "heading.6.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#F4AC6F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F4AC6F",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#EED886",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Strikethrough",
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#9FA0B0",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#7FDCD4"
      }
    },
    {
      "name": "Markdown Blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#AFAFBF",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown List",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin"
      ],
      "settings": {
        "foreground": "#84DBF2"
      }
    },
    {
      "name": "Markdown Link Text",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#83BDFF"
      }
    },
    {
      "name": "Markdown Link URL",
      "scope": [
        "markup.underline.link.markdown",
        "meta.link.inline.markdown markup.underline"
      ],
      "settings": {
        "foreground": "#84DBF2",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown Punctuation",
      "scope": [
        "punctuation.definition.heading.markdown",
        "punctuation.definition.bold.markdown",
        "punctuation.definition.italic.markdown",
        "punctuation.definition.quote.begin.markdown",
        "punctuation.definition.markdown"
      ],
      "settings": {
        "foreground": "#636374"
      }
    },
    {
      "name": "Markdown Separator",
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#4B4B5D"
      }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#7FDCD4"
      }
    },
    {
      "name": "YAML Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#7FDCD4"
      }
    },
    {
      "name": "YAML Plain Strings",
      "scope": [
        "string.unquoted.yaml"
      ],
      "settings": {
        "foreground": "#86DC90"
      }
    },
    {
      "name": "CSS Class",
      "scope": [
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#EED886"
      }
    },
    {
      "name": "CSS Id",
      "scope": [
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#83BDFF"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#7FDCD4"
      }
    },
    {
      "name": "HTML Tag",
      "scope": [
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#83BDFF"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#EED886"
      }
    },
    {
      "name": "Shell Variables",
      "scope": [
        "variable.other.normal.shell",
        "variable.parameter.positional.shell"
      ],
      "settings": {
        "foreground": "#EC9DA3"
      }
    },
    {
      "name": "Shell Builtins",
      "scope": [
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#83BDFF"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#86DC90"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#F27972"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#EED886"
      }
    }
  ]
}
