{
  "name": "LBB Builder Aurora",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#121322",
    "editor.foreground": "#E3E5F2",
    "editorLineNumber.foreground": "#5F6177",
    "editorLineNumber.activeForeground": "#E3E5F2",
    "editorGutter.background": "#050512",
    "editorCursor.foreground": "#C3A1FF",
    "editorIndentGuide.background1": "#232439",
    "editorIndentGuide.activeBackground1": "#43465C",
    "editorWhitespace.foreground": "#313349",
    "editorRuler.foreground": "#232439",
    "sideBar.background": "#050512",
    "sideBar.foreground": "#CACDDC",
    "sideBar.border": "#050512",
    "sideBarSectionHeader.background": "#0B0C1A",
    "sideBarSectionHeader.foreground": "#E3E5F2",
    "sideBarTitle.foreground": "#E3E5F2",
    "activityBar.background": "#050512",
    "activityBar.foreground": "#E3E5F2",
    "activityBar.inactiveForeground": "#5F6177",
    "activityBarBadge.background": "#C3A1FF",
    "activityBarBadge.foreground": "#050512",
    "activityBar.activeBorder": "#C3A1FF",
    "titleBar.activeBackground": "#050512",
    "titleBar.activeForeground": "#E3E5F2",
    "titleBar.inactiveBackground": "#050512",
    "titleBar.inactiveForeground": "#787A8F",
    "statusBar.background": "#0B0C1A",
    "statusBar.foreground": "#CACDDC",
    "statusBar.noFolderBackground": "#0B0C1A",
    "statusBar.debuggingBackground": "#F8959E",
    "statusBar.debuggingForeground": "#050512",
    "panel.background": "#0B0C1A",
    "panel.border": "#050512",
    "panelTitle.activeForeground": "#E3E5F2",
    "panelTitle.inactiveForeground": "#5F6177",
    "list.hoverBackground": "#232439",
    "list.activeSelectionBackground": "#313349",
    "list.activeSelectionForeground": "#E3E5F2",
    "list.inactiveSelectionBackground": "#232439",
    "list.inactiveSelectionForeground": "#E3E5F2",
    "list.highlightForeground": "#C3A1FF",
    "editorGroup.border": "#050512",
    "editorGroupHeader.tabsBackground": "#050512",
    "tab.activeBackground": "#121322",
    "tab.activeForeground": "#E3E5F2",
    "tab.inactiveBackground": "#050512",
    "tab.inactiveForeground": "#5F6177",
    "tab.border": "#050512",
    "tab.activeBorderTop": "#C3A1FF",
    "tab.hoverBackground": "#232439",
    "focusBorder": "#C3A1FF",
    "foreground": "#CACDDC",
    "selection.background": "#C3A1FF40",
    "editor.selectionBackground": "#43465C80",
    "editor.inactiveSelectionBackground": "#31334955",
    "editor.selectionHighlightBackground": "#31334955",
    "editor.lineHighlightBackground": "#E3E5F212",
    "editor.findMatchBackground": "#F2D76C66",
    "editor.findMatchHighlightBackground": "#F2D76C33",
    "editor.wordHighlightBackground": "#C3A1FF26",
    "editor.wordHighlightStrongBackground": "#C3A1FF26",
    "editorBracketMatch.background": "#C3A1FF26",
    "editorBracketMatch.border": "#C3A1FF00",
    "editorError.foreground": "#F86B65",
    "editorWarning.foreground": "#F2D76C",
    "editorInfo.foreground": "#6EE0FC",
    "editorGutter.addedBackground": "#78E186",
    "editorGutter.modifiedBackground": "#86BFFF",
    "editorGutter.deletedBackground": "#F86B65",
    "gitDecoration.addedResourceForeground": "#78E186",
    "gitDecoration.modifiedResourceForeground": "#F2D76C",
    "gitDecoration.deletedResourceForeground": "#F86B65",
    "gitDecoration.untrackedResourceForeground": "#61E3D8",
    "terminal.background": "#121322",
    "terminal.foreground": "#CACDDC",
    "terminalCursor.foreground": "#C3A1FF",
    "terminal.selectionBackground": "#43465C80",
    "terminal.ansiBlack": "#313349",
    "terminal.ansiRed": "#F86B65",
    "terminal.ansiGreen": "#78E186",
    "terminal.ansiYellow": "#F2D76C",
    "terminal.ansiBlue": "#86BFFF",
    "terminal.ansiMagenta": "#C3A1FF",
    "terminal.ansiCyan": "#61E3D8",
    "terminal.ansiWhite": "#CACDDC",
    "terminal.ansiBrightBlack": "#5F6177",
    "terminal.ansiBrightRed": "#F8959E",
    "terminal.ansiBrightGreen": "#78E186",
    "terminal.ansiBrightYellow": "#FFA659",
    "terminal.ansiBrightBlue": "#6EE0FC",
    "terminal.ansiBrightMagenta": "#FFA3CF",
    "terminal.ansiBrightCyan": "#6EE0FC",
    "terminal.ansiBrightWhite": "#E3E5F2"
  },
  "semanticTokenColors": {
    "parameter": "#F8959E",
    "property": "#61E3D8",
    "variable.readonly": "#F2D76C",
    "function": "#86BFFF",
    "method": "#86BFFF",
    "class": "#F2D76C",
    "interface": "#F2D76C",
    "enum": "#F2D76C",
    "type": "#F2D76C",
    "namespace": "#F2D76C",
    "enumMember": "#F2D76C",
    "typeParameter": "#FFA659",
    "decorator": "#FFA659"
  },
  "tokenColors": [
    {
      "settings": {
        "foreground": "#E3E5F2",
        "background": "#121322"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9DA0B4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#78E186"
      }
    },
    {
      "name": "Escape Characters",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#FFA3CF"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#86BFFF"
      }
    },
    {
      "name": "Keywords & Storage",
      "scope": [
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#C3A1FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control"
      ],
      "settings": {
        "foreground": "#FFA3CF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.hex"
      ],
      "settings": {
        "foreground": "#FFA659"
      }
    },
    {
      "name": "Boolean & Language Constants",
      "scope": [
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#F8959E"
      }
    },
    {
      "name": "Variables & Identifiers",
      "scope": [
        "variable",
        "identifier",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#E3E5F2"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#F8959E"
      }
    },
    {
      "name": "Types & Classes",
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "support.class"
      ],
      "settings": {
        "foreground": "#F2D76C"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#6EE0FC"
      }
    },
    {
      "name": "Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#F2D76C"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#6EE0FC"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#86899E"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "storage.type.annotation",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#FFA659"
      }
    },
    {
      "name": "Constants & Enums",
      "scope": [
        "variable.other.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#F2D76C"
      }
    },
    {
      "name": "Object Keys",
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#61E3D8"
      }
    },
    {
      "name": "Invalid & Deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#F86B65"
      }
    },
    {
      "name": "Embedded Source",
      "scope": [
        "source.css.embedded",
        "source.js.embedded"
      ],
      "settings": {
        "foreground": "#6EE0FC"
      }
    },
    {
      "name": "Inherited Class",
      "scope": [
        "entity.other.inherited-class"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown H1",
      "scope": [
        "markup.heading.1",
        "heading.1.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#C3A1FF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H2",
      "scope": [
        "markup.heading.2",
        "heading.2.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#86BFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H3",
      "scope": [
        "markup.heading.3",
        "heading.3.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#6EE0FC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H4",
      "scope": [
        "markup.heading.4",
        "heading.4.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#61E3D8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H5",
      "scope": [
        "markup.heading.5",
        "heading.5.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#78E186",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown H6",
      "scope": [
        "markup.heading.6",
        "heading.6.markdown entity.name.section"
      ],
      "settings": {
        "foreground": "#FFA659",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFA659",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#F2D76C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Strikethrough",
      "scope": [
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#9DA0B4",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#61E3D8"
      }
    },
    {
      "name": "Markdown Blockquote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#B0B3C5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown List",
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin"
      ],
      "settings": {
        "foreground": "#6EE0FC"
      }
    },
    {
      "name": "Markdown Link Text",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "markup.link"
      ],
      "settings": {
        "foreground": "#86BFFF"
      }
    },
    {
      "name": "Markdown Link URL",
      "scope": [
        "markup.underline.link.markdown",
        "meta.link.inline.markdown markup.underline"
      ],
      "settings": {
        "foreground": "#6EE0FC",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown Punctuation",
      "scope": [
        "punctuation.definition.heading.markdown",
        "punctuation.definition.bold.markdown",
        "punctuation.definition.italic.markdown",
        "punctuation.definition.quote.begin.markdown",
        "punctuation.definition.markdown"
      ],
      "settings": {
        "foreground": "#606378"
      }
    },
    {
      "name": "Markdown Separator",
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#44465B"
      }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#61E3D8"
      }
    },
    {
      "name": "YAML Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#61E3D8"
      }
    },
    {
      "name": "YAML Plain Strings",
      "scope": [
        "string.unquoted.yaml"
      ],
      "settings": {
        "foreground": "#78E186"
      }
    },
    {
      "name": "CSS Class",
      "scope": [
        "entity.other.attribute-name.class.css"
      ],
      "settings": {
        "foreground": "#F2D76C"
      }
    },
    {
      "name": "CSS Id",
      "scope": [
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#86BFFF"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#61E3D8"
      }
    },
    {
      "name": "HTML Tag",
      "scope": [
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#6EE0FC"
      }
    },
    {
      "name": "HTML Attribute",
      "scope": [
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#F2D76C"
      }
    },
    {
      "name": "Shell Variables",
      "scope": [
        "variable.other.normal.shell",
        "variable.parameter.positional.shell"
      ],
      "settings": {
        "foreground": "#F8959E"
      }
    },
    {
      "name": "Shell Builtins",
      "scope": [
        "support.function.builtin.shell"
      ],
      "settings": {
        "foreground": "#86BFFF"
      }
    },
    {
      "name": "Diff Inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#78E186"
      }
    },
    {
      "name": "Diff Deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#F86B65"
      }
    },
    {
      "name": "Diff Changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#F2D76C"
      }
    }
  ]
}
